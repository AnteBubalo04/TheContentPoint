@page "/landing"
@using System.Net.Http.Json
@inject HttpClient Http

@if (!submitted)
{
    <h3>Unesi email</h3>
    <input @bind="email" placeholder="Unesi email" />
    <button @onclick="SubmitEmail">Pošalji</button>
}
else
{
    <h3>Email poslan. Hvala!</h3>
    <p>Možeš sada snimiti fotografiju na uređaju.</p>
}

@code {
    private string email = string.Empty;
    private bool submitted = false;

    private class Session
    {
        public string Id { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
    }

    private async Task SubmitEmail()
    {
        var normalizedEmail = email.Trim();

        if (string.IsNullOrWhiteSpace(normalizedEmail))
        {
            Console.WriteLine("[LANDING ERROR] Email je prazan.");
            return;
        }

        var payload = new Session
        {
            Email = normalizedEmail
        };

        try
        {
            var response = await Http.PostAsJsonAsync("api/session/active/email", payload);

            if (response.IsSuccessStatusCode)
            {
                submitted = true;
                Console.WriteLine("[LANDING] Email poslan za trenutno aktivni session.");

                await Task.Delay(1500);

                email = string.Empty;
                submitted = false;
                StateHasChanged();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"[LANDING ERROR] {error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LANDING EXCEPTION] {ex.Message}");
        }
    }
}