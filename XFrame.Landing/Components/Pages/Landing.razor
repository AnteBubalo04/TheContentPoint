@page "/landing"
@using System.Net.Http.Json
@inject HttpClient Http

@if (!submitted)
{
    <h3>Unesi email</h3>
    <input @bind="email" placeholder="Unesi email" />
    <button @onclick="SubmitEmail">Pošalji</button>
}
else
{
    <h3>Email poslan. Hvala!</h3>
    <p>Možeš sada snimiti fotografiju na uređaju.</p>
}

@code {
    private string email = string.Empty;
    private string sessionId = string.Empty;
    private bool submitted = false;

    private class SessionResponse
    {
        public string SessionId { get; set; } = string.Empty;
    }

    private class Session
    {
        public string Id { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        await RefreshActiveSessionId();
    }

    private async Task RefreshActiveSessionId()
    {
        try
        {
            var ts = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            var response = await Http.GetFromJsonAsync<SessionResponse>($"api/session/active?ts={ts}");

            sessionId = response?.SessionId ?? "";
            Console.WriteLine($"[LANDING] Dohvaćen sessionId: {sessionId}");
        }
        catch (Exception ex)
        {
            sessionId = string.Empty;
            Console.WriteLine($"[LANDING ERROR] Ne mogu dohvatiti sessionId: {ex.Message}");
        }
    }

    private async Task SubmitEmail()
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            Console.WriteLine("[LANDING ERROR] Email je prazan.");
            return;
        }

        // UVIJEK prije slanja povuci trenutni active session
        await RefreshActiveSessionId();

        if (string.IsNullOrWhiteSpace(sessionId))
        {
            Console.WriteLine("[LANDING ERROR] sessionId je prazan.");
            return;
        }

        var payload = new Session
        {
            Id = sessionId,
            Email = email
        };

        try
        {
            var response = await Http.PostAsJsonAsync($"api/session/{sessionId}/email", payload);

            if (response.IsSuccessStatusCode)
            {
                submitted = true;
                Console.WriteLine($"[LANDING] Email poslan za session {sessionId}");

                await Task.Delay(5000);

                email = string.Empty;
                submitted = false;

                // pripremi landing za iduće slanje tako da povuče novi active session
                await RefreshActiveSessionId();

                StateHasChanged();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"[LANDING ERROR] {error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LANDING EXCEPTION] {ex.Message}");
        }
    }
}