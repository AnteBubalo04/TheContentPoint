@page "/device"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Threading
@inject IJSRuntime JS
@inject HttpClient Http

<div style="position: relative; width: 100vw; height: 100vh; overflow: hidden;">
    <canvas id="canvas" width="1080" height="1920"></canvas>
    <div id="countdown" class="countdown-overlay hidden">5</div>
</div>

@code {
    private string sessionId = Guid.NewGuid().ToString();
    private bool _initialized = false;

    private string _lastObservedSessionId = string.Empty;
    private string _lastObservedEmail = string.Empty;

    private string _lastHandledSessionId = string.Empty;
    private string _lastHandledEmail = string.Empty;

    private int _isProcessing = 0;

    private class ActiveSessionStateResponse
    {
        public string SessionId { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;

            await Http.PostAsJsonAsync($"api/session/{sessionId}/register", new { Id = sessionId });

            await JS.InvokeVoidAsync("drawOverlayOnly");
            await Task.Delay(150);
            await JS.InvokeVoidAsync("drawOverlayOnly");

            _ = PollForEmail();
        }
    }

    private async Task PollForEmail()
    {
        while (true)
        {
            try
            {
                var url =
                    $"api/session/active-state/wait" +
                    $"?lastKnownSessionId={Uri.EscapeDataString(_lastObservedSessionId)}" +
                    $"&lastKnownEmail={Uri.EscapeDataString(_lastObservedEmail)}" +
                    $"&timeoutMs=15000" +
                    $"&ts={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}";

                var state = await Http.GetFromJsonAsync<ActiveSessionStateResponse>(url);

                if (state is null)
                {
                    await Task.Delay(150);
                    continue;
                }

                var activeId = state.SessionId?.Trim() ?? string.Empty;
                var email = state.Email?.Trim() ?? string.Empty;

                _lastObservedSessionId = activeId;
                _lastObservedEmail = email;

                if (_lastHandledSessionId != activeId)
                {
                    _lastHandledSessionId = string.Empty;
                    _lastHandledEmail = string.Empty;
                }

                if (!string.IsNullOrWhiteSpace(activeId) &&
                    !string.IsNullOrWhiteSpace(email) &&
                    (_lastHandledSessionId != activeId || _lastHandledEmail != email))
                {
                    _lastHandledSessionId = activeId;
                    _lastHandledEmail = email;

                    await HandleCaptureAndUploadAsync(activeId);
                }
            }
            catch
            {
                await Task.Delay(500);
            }
        }
    }

    private async Task HandleCaptureAndUploadAsync(string activeId)
    {
        if (Interlocked.Exchange(ref _isProcessing, 1) == 1)
            return;

        try
        {
            var dataUrl = await JS.InvokeAsync<string?>("startCameraWithSmoothTransition", activeId);

            if (string.IsNullOrWhiteSpace(dataUrl))
                return;

            var commaIndex = dataUrl.IndexOf(',');
            if (commaIndex < 0 || commaIndex == dataUrl.Length - 1)
                throw new InvalidOperationException("Neispravan dataUrl za sliku.");

            var base64 = dataUrl[(commaIndex + 1)..];
            var photoBytes = Convert.FromBase64String(base64);

            using var form = new MultipartFormDataContent();
            using var fileContent = new ByteArrayContent(photoBytes);

            fileContent.Headers.ContentType = new MediaTypeHeaderValue("image/jpeg");
            form.Add(fileContent, "photo", $"{activeId}.jpg");

            var response = await Http.PostAsync($"api/session/{activeId}/photo", form);

            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"[DEVICE ERROR] Upload photo failed for session {activeId}: {error}");
            }
            else
            {
                Console.WriteLine($"[DEVICE] Photo uploaded for session {activeId}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[DEVICE EXCEPTION] {ex.Message}");
        }
        finally
        {
            try
            {
                await JS.InvokeVoidAsync("waitForHeroFlowToFinish");
            }
            catch
            {
            }

            Interlocked.Exchange(ref _isProcessing, 0);
        }
    }
}